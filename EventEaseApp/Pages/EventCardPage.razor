@page "/event-card"

@using EventEaseApp.Shared

<PageTitle>Event Card</PageTitle>

<h1>Tarjetas de Evento</h1>

<p>Ejemplo con una lista dinámica de eventos y enlace de datos bidireccional:</p>

@foreach (var evento in Eventos)
{
    <EventCard @bind-Nombre="evento.Nombre" @bind-Fecha="evento.Fecha" @bind-Ubicacion="evento.Ubicacion" />
}

@code {
    private List<EventModel> Eventos = new()
    {
        new EventModel { Nombre = "Concierto de Primavera", Fecha = new DateTime(2026, 5, 24), Ubicacion = "Auditorio Central" },
        new EventModel { Nombre = "Feria de Tecnología", Fecha = new DateTime(2026, 6, 12), Ubicacion = "Centro de Convenciones" },
        new EventModel { Nombre = "Exposición de Arte", Fecha = new DateTime(2026, 7, 5), Ubicacion = "Galería del Pueblo" }
    };
}
